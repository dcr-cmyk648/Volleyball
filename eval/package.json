{
  "name": "vball-eval",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "quality": "node --no-deprecation --import ./register.mjs quality.mjs",
    "margin": "node --no-deprecation --import ./register.mjs margin_sweep.mjs",
    "margin:grid": "node --no-deprecation --import ./register.mjs margin_grid.mjs",
    "league": "node --no-deprecation --import ./register.mjs league_sweep.mjs",
    "balance": "node --no-deprecation --import ./register.mjs balancing_quality.mjs",
    "balance:iq": "node --no-deprecation --import ./register.mjs balance_iq_sweep.mjs",
    "baseline:compare": "node --no-deprecation --import ./register.mjs dashboard_baseline_compare.mjs",
    "balancer:grid": "node --no-deprecation --import ./register.mjs balancer_grid.mjs",
    "probscale": "node --no-deprecation --import ./register.mjs probability_scale_sweep.mjs",
    "carry": "node --no-deprecation --import ./register.mjs carry_sweep.mjs",
    "probtemp": "node --no-deprecation --import ./register.mjs probability_temperature_sweep.mjs",
    "league:team": "node --no-deprecation --import ./register.mjs league_team_sweep.mjs",
    "closewin": "node --no-deprecation --import ./register.mjs close_win_sweep.mjs",
    "size:effects": "node --no-deprecation --import ./register.mjs size_effects.mjs",
    "size:bonus": "node --no-deprecation --import ./register.mjs size_bonus_sweep.mjs",
    "back:balancer": "node --no-deprecation --import ./register.mjs back_explanatory_balancer.mjs",
    "update:context": "node --no-deprecation --import ./register.mjs update_context_sweep.mjs",
    "volatility": "node --no-deprecation --import ./register.mjs volatility_sweep.mjs",
    "volatility:balancer": "node --no-deprecation --import ./register.mjs volatility_balancer_sweep.mjs",
    "pair:risk": "node --no-deprecation --import ./register.mjs pair_risk_balancer_sweep.mjs",
    "team:floor": "node --no-deprecation --import ./register.mjs team_floor_balancer_sweep.mjs",
    "expected:outliers": "node --no-deprecation --import ./register.mjs expected_range_outliers.mjs",
    "uncertainty:audit": "node --no-deprecation --import ./register.mjs player_uncertainty_audit.mjs",
    "openskill:native": "node --no-deprecation --import ./register.mjs openskill_native_sweep.mjs",
    "rating:backfit": "node --no-deprecation --import ./register.mjs rating_backfit_sweep.mjs",
    "streak": "OPEN_SKILL_NATIVE_SWEEP=streak node --no-deprecation --import ./register.mjs openskill_native_sweep.mjs",
    "session": "OPEN_SKILL_NATIVE_SWEEP=session node --no-deprecation --import ./register.mjs openskill_native_sweep.mjs",
    "release:compare": "node --no-deprecation --import ./register.mjs release_compare.mjs",
    "release:compare:balancer": "RELEASE_COMPARE_SCORING=balancer node --no-deprecation --import ./register.mjs release_compare.mjs"
  },
  "dependencies": {
    "openskill": "4.1.1"
  }
}
